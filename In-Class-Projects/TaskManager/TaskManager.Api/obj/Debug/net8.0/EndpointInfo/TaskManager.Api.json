            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestRegisterTaskJson"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RequestRegisterTaskJson"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Task"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
